<?xml version="1.0" encoding="UTF-8"?>
<!--
    ============================================================================
    Cppcheck Suppressions for MISRA C:2012 Compliance
    Project: ETH-DDS Integration (Automotive Ethernet Stack)
    ============================================================================
    Usage: cppcheck --suppressions-list=cppcheck_suppressions.xml <files>
    ============================================================================
-->
<suppressions>
    <!-- ============================================================================
         THIRD-PARTY CODE SUPPRESSIONS
         Deviation Permit: TP-001
         Justification: External library code not under project control
    ============================================================================ -->
    
    <!-- FreeRTOS kernel -->
    <suppress>
        <id>misra-c2012-2.7</id>
        <fileName>*/freertos/*</fileName>
        <symbolName>*</symbolName>
        <reason>Third-party: FreeRTOS kernel</reason>
    </suppress>
    
    <!-- lwIP stack -->
    <suppress>
        <id>misra-c2012-*</id>
        <fileName>*/lwip/*</fileName>
        <reason>Third-party: lwIP networking stack</reason>
    </suppress>
    
    <!-- CMSIS headers -->
    <suppress>
        <id>misra-c2012-*</id>
        <fileName>*/cmsis/*</fileName>
        <reason>Third-party: ARM CMSIS</reason>
    </suppress>
    
    <!-- Hardware abstraction headers -->
    <suppress>
        <id>misra-c2012-*</id>
        <fileName>*/hal/*</fileName>
        <reason>Third-party: Hardware Abstraction Layer</reason>
    </suppress>

    <!-- ============================================================================
         AUTO-GENERATED CODE SUPPRESSIONS
         Deviation Permit: AUTO-001
         Justification: Code generated by tools, manual modification not allowed
    ============================================================================ -->
    
    <!-- Generated configuration code -->
    <suppress>
        <id>misra-c2012-20.7</id>
        <fileName>*/generated/*</fileName>
        <reason>Auto-generated: Configuration code</reason>
    </suppress>
    
    <!-- ARXML generated code -->
    <suppress>
        <id>misra-c2012-*</id>
        <fileName>*/arxml_gen/*</fileName>
        <reason>Auto-generated: ARXML tooling output</reason>
    </suppress>

    <!-- ============================================================================
         PERFORMANCE-CRITICAL CODE SUPPRESSIONS
         Deviation Permit: PERF-001
         Justification: Timing constraints require specific coding patterns
    ============================================================================ -->
    
    <!-- Rule 15.5: Single exit point
         Suppressed in ISR context where early return optimizes latency -->
    <suppress>
        <id>misra-c2012-15.5</id>
        <fileName>*interrupt*.c</fileName>
        <reason>Performance: ISR latency optimization</reason>
    </suppress>
    
    <!-- Rule 15.5: Single exit point for hardware polling loops -->
    <suppress>
        <id>misra-c2012-15.5</id>
        <fileName>*eth_driver*.c</fileName>
        <reason>Performance: Hardware register polling</reason>
    </suppress>

    <!-- ============================================================================
         HARDWARE ACCESS SUPPRESSIONS
         Deviation Permit: HW-001
         Justification: Direct hardware register access requires specific patterns
    ============================================================================ -->
    
    <!-- Rule 11.4: Pointer to integer conversion
         Required for memory-mapped register access -->
    <suppress>
        <id>misra-c2012-11.4</id>
        <fileName>*_regs.h</fileName>
        <symbolName>*REG*</symbolName>
        <reason>Hardware: Memory-mapped register address definition</reason>
    </suppress>
    
    <suppress>
        <id>misra-c2012-11.4</id>
        <fileName>*platform*</fileName>
        <symbolName>*HW_</symbolName>
        <reason>Hardware: Platform register access</reason>
    </suppress>
    
    <!-- Rule 11.6: Cast to pointer from integer
         Required for defining register base addresses -->
    <suppress>
        <id>misra-c2012-11.6</id>
        <fileName>*_regs.h</fileName>
        <symbolName>*BASE_ADDR*</symbolName>
        <reason>Hardware: Register base address definition</reason>
    </suppress>
    
    <!-- Rule 19.2: Union usage
         Required for register access with different interpretations -->
    <suppress>
        <id>misra-c2012-19.2</id>
        <fileName>*_regs.h</fileName>
        <reason>Hardware: Register bit-field access via union</reason>
    </suppress>

    <!-- ============================================================================
         INLINE ASSEMBLY SUPPRESSIONS
         Deviation Permit: ASM-001
         Justification: Low-level operations require assembly
    ============================================================================ -->
    
    <!-- Rule 1.1: ISO C compliance -->
    <suppress>
        <id>misra-c2012-1.1</id>
        <fileName>*</fileName>
        <symbolName>__asm__</symbolName>
        <reason>Assembly: Inline assembly for critical operations</reason>
    </suppress>
    
    <!-- Rule 20.4: Keyword-like macro -->
    <suppress>
        <id>misra-c2012-20.4</id>
        <fileName>*</fileName>
        <symbolName>ASM</symbolName>
        <reason>Assembly: Inline assembly macro</reason>
    </suppress>

    <!-- ============================================================================
         SPECIFIC RULE DEVIATIONS (Require individual justification)
    ============================================================================ -->
    
    <!-- Rule 17.7: Return value not used
         Allowed for intentional fire-and-forget operations -->
    <suppress>
        <id>misra-c2012-17.7</id>
        <fileName>*</fileName>
        <symbolName>Debug_Log</symbolName>
        <reason>Logging: Debug functions may have return values that are intentionally ignored in production</reason>
    </suppress>
    
    <suppress>
        <id>misra-c2012-17.7</id>
        <fileName>*</fileName>
        <symbolName>memcpy</symbolName>
        <reason>Standard library: memcpy return value rarely needed</reason>
    </suppress>
    
    <!-- Rule 8.13: Const pointer recommendation
         False positives in callbacks where const changes API -->
    <suppress>
        <id>misra-c2012-8.13</id>
        <fileName>*callback*.c</fileName>
        <reason>API compatibility: Callback signatures must match interface</reason>
    </suppress>
    
    <!-- Rule 14.4: Boolean in loop
         Common pattern for status checks -->
    <suppress>
        <id>misra-c2012-14.4</id>
        <fileName>*</fileName>
        <symbolName>*Status*</symbolName>
        <reason>Style: Status variable in while loop is intentional</reason>
    </suppress>
    
    <!-- Rule 7.4: String literal assignment
         Common for error messages -->
    <suppress>
        <id>misra-c2012-7.4</id>
        <fileName>*</fileName>
        <symbolName>*ErrorString*</symbolName>
        <reason>Readability: Error message assignment pattern</reason>
    </suppress>

    <!-- ============================================================================
         TEST CODE SUPPRESSIONS (Test files only)
    ============================================================================ -->
    
    <suppress>
        <id>misra-c2012-*</id>
        <fileName>*/tests/*</fileName>
        <reason>Test code: Not part of production deliverables</reason>
    </suppress>
    
    <suppress>
        <id>misra-c2012-*</id>
        <fileName>*test*.c</fileName>
        <reason>Test code: Unit test files</reason>
    </suppress>
    
    <suppress>
        <id>misra-c2012-*</id>
        <fileName>*mock*.c</fileName>
        <reason>Test code: Mock implementations</reason>
    </suppress>

    <!-- ============================================================================
         SPECIFIC FILE DEVIATIONS (Documented per-file)
    ============================================================================ -->
    
    <!-- E2E Profile configurations may violate Rule 20.7 -->
    <suppress>
        <id>misra-c2012-20.7</id>
        <fileName>*e2e_profile*.c</fileName>
        <reason>Configuration: E2E profile macros with complex expressions</reason>
    </suppress>
    
    <!-- SecOC crypto operations may have complex expressions -->
    <suppress>
        <id>misra-c2012-12.1</id>
        <fileName>*secoc*.c</fileName>
        <reason>Cryptography: Complex bitwise operations are intentional</reason>
    </suppress>
    
    <!-- OTA parser state machine -->
    <suppress>
        <id>misra-c2012-15.5</id>
        <fileName>ota_parser.c</fileName>
        <reason>State machine: Multiple returns simplify error handling</reason>
    </suppress>
    
    <!-- UDS service handlers may have multiple returns -->
    <suppress>
        <id>misra-c2012-15.5</id>
        <fileName>*dcm_service*.c</fileName>
        <reason>UDS services: Standard service handler pattern</reason>
    </suppress>
    
    <!-- ============================================================================
         TEMPORARY SUPPRESSIONS (Must be resolved before release)
    ============================================================================ -->
    
    <!-- TODO: Remove after refactoring -->
    <suppress>
        <id>misra-c2012-2.1</id>
        <fileName>bl_rollback.c</fileName>
        <line>245</line>
        <reason>TEMPORARY: Dead code to be removed in next sprint</reason>
    </suppress>
    
    <suppress>
        <id>misra-c2012-2.2</id>
        <fileName>ota_downloader.c</fileName>
        <line>178</line>
        <reason>TEMPORARY: Debug code to be removed</reason>
    </suppress>

</suppressions>
