<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>DDS_ADAS_Configuration</SHORT-NAME>
      <ELEMENTS>
        <DDS-DOMAIN-PARTICIPANT-CONFIG>
          <SHORT-NAME>Domain1_PerceptionDomain</SHORT-NAME>
          <DOMAIN-ID>1</DOMAIN-ID>
          <DDS-DOMAIN-PARTICIPANT>
            <SHORT-NAME>CameraECU</SHORT-NAME>
            <QOS-PROFILE-REF DEST="DDS-QOS-PROFILE">sensor_high_reliability</QOS-PROFILE-REF>
            <DDS-PUBLISHER>
              <TOPIC-REF DEST="DDS-TOPIC-CONFIG">CameraObjectDetection</TOPIC-REF>
              <DATA-TYPE>ObjectDetectionData</DATA-TYPE>
              <DDS-QOS>
                <RELIABILITY>RELIABLE</RELIABILITY>
                <DURABILITY>VOLATILE</DURABILITY>
                <HISTORY>KEEP_LAST</HISTORY>
                <HISTORY-DEPTH>1</HISTORY-DEPTH>
                <DEADLINE>
                  <SEC>0</SEC>
                  <NANOSEC>33000000</NANOSEC>
                </DEADLINE>
                <LIVELINESS>AUTOMATIC</LIVELINESS>
              </DDS-QOS>
            </DDS-PUBLISHER>
            <DDS-PUBLISHER>
              <TOPIC-REF DEST="DDS-TOPIC-CONFIG">CameraImage</TOPIC-REF>
              <DATA-TYPE>ImageData</DATA-TYPE>
              <DDS-QOS>
                <RELIABILITY>BEST_EFFORT</RELIABILITY>
                <DURABILITY>VOLATILE</DURABILITY>
                <HISTORY>KEEP_LAST</HISTORY>
                <HISTORY-DEPTH>2</HISTORY-DEPTH>
                <LIVELINESS>AUTOMATIC</LIVELINESS>
              </DDS-QOS>
            </DDS-PUBLISHER>
          </DDS-DOMAIN-PARTICIPANT>
          <DDS-DOMAIN-PARTICIPANT>
            <SHORT-NAME>RadarECU</SHORT-NAME>
            <DDS-PUBLISHER>
              <TOPIC-REF DEST="DDS-TOPIC-CONFIG">RadarData</TOPIC-REF>
              <DATA-TYPE>RadarPointCloud</DATA-TYPE>
              <DDS-QOS>
                <RELIABILITY>RELIABLE</RELIABILITY>
                <DURABILITY>VOLATILE</DURABILITY>
                <HISTORY>KEEP_LAST</HISTORY>
                <HISTORY-DEPTH>1</HISTORY-DEPTH>
                <DEADLINE>
                  <SEC>0</SEC>
                  <NANOSEC>20000000</NANOSEC>
                </DEADLINE>
                <LIVELINESS>AUTOMATIC</LIVELINESS>
              </DDS-QOS>
            </DDS-PUBLISHER>
            <DDS-SUBSCRIBER>
              <TOPIC-REF DEST="DDS-TOPIC-CONFIG">FusedObjects</TOPIC-REF>
              <DATA-TYPE>ObjectList</DATA-TYPE>
              <DDS-QOS>
                <RELIABILITY>RELIABLE</RELIABILITY>
                <DURABILITY>VOLATILE</DURABILITY>
                <HISTORY>KEEP_LAST</HISTORY>
                <HISTORY-DEPTH>1</HISTORY-DEPTH>
                <LIVELINESS>AUTOMATIC</LIVELINESS>
              </DDS-QOS>
            </DDS-SUBSCRIBER>
          </DDS-DOMAIN-PARTICIPANT>
        </DDS-DOMAIN-PARTICIPANT-CONFIG>
        <DDS-DOMAIN-PARTICIPANT-CONFIG>
          <SHORT-NAME>Domain2_ControlDomain</SHORT-NAME>
          <DOMAIN-ID>2</DOMAIN-ID>
          <DDS-DOMAIN-PARTICIPANT>
            <SHORT-NAME>PlanningECU</SHORT-NAME>
            <QOS-PROFILE-REF DEST="DDS-QOS-PROFILE">control_realtime</QOS-PROFILE-REF>
            <DDS-PUBLISHER>
              <TOPIC-REF DEST="DDS-TOPIC-CONFIG">FusedObjects</TOPIC-REF>
              <DATA-TYPE>ObjectList</DATA-TYPE>
              <DDS-QOS>
                <RELIABILITY>RELIABLE</RELIABILITY>
                <DURABILITY>TRANSIENT_LOCAL</DURABILITY>
                <HISTORY>KEEP_LAST</HISTORY>
                <HISTORY-DEPTH>10</HISTORY-DEPTH>
                <LIVELINESS>AUTOMATIC</LIVELINESS>
              </DDS-QOS>
            </DDS-PUBLISHER>
            <DDS-SUBSCRIBER>
              <TOPIC-REF DEST="DDS-TOPIC-CONFIG">CameraObjectDetection</TOPIC-REF>
              <DATA-TYPE>ObjectDetectionData</DATA-TYPE>
              <DDS-QOS>
                <RELIABILITY>RELIABLE</RELIABILITY>
                <DURABILITY>VOLATILE</DURABILITY>
                <HISTORY>KEEP_LAST</HISTORY>
                <HISTORY-DEPTH>1</HISTORY-DEPTH>
                <LIVELINESS>AUTOMATIC</LIVELINESS>
              </DDS-QOS>
            </DDS-SUBSCRIBER>
            <DDS-SUBSCRIBER>
              <TOPIC-REF DEST="DDS-TOPIC-CONFIG">RadarData</TOPIC-REF>
              <DATA-TYPE>RadarPointCloud</DATA-TYPE>
              <DDS-QOS>
                <RELIABILITY>RELIABLE</RELIABILITY>
                <DURABILITY>VOLATILE</DURABILITY>
                <HISTORY>KEEP_LAST</HISTORY>
                <HISTORY-DEPTH>1</HISTORY-DEPTH>
                <LIVELINESS>AUTOMATIC</LIVELINESS>
              </DDS-QOS>
            </DDS-SUBSCRIBER>
          </DDS-DOMAIN-PARTICIPANT>
        </DDS-DOMAIN-PARTICIPANT-CONFIG>
        <DDS-QOS-PROFILE>
          <SHORT-NAME>sensor_high_reliability</SHORT-NAME>
          <DDS-QOS>
            <RELIABILITY>RELIABLE</RELIABILITY>
            <DURABILITY>VOLATILE</DURABILITY>
            <HISTORY>KEEP_LAST</HISTORY>
            <HISTORY-DEPTH>1</HISTORY-DEPTH>
            <DEADLINE>
              <SEC>0</SEC>
              <NANOSEC>33000000</NANOSEC>
            </DEADLINE>
            <LIVELINESS>AUTOMATIC</LIVELINESS>
          </DDS-QOS>
        </DDS-QOS-PROFILE>
        <DDS-QOS-PROFILE>
          <SHORT-NAME>control_realtime</SHORT-NAME>
          <DDS-QOS>
            <RELIABILITY>RELIABLE</RELIABILITY>
            <DURABILITY>TRANSIENT_LOCAL</DURABILITY>
            <HISTORY>KEEP_LAST</HISTORY>
            <HISTORY-DEPTH>10</HISTORY-DEPTH>
            <LIVELINESS>AUTOMATIC</LIVELINESS>
          </DDS-QOS>
        </DDS-QOS-PROFILE>
        <DDS-QOS-PROFILE>
          <SHORT-NAME>best_effort_sensor</SHORT-NAME>
          <DDS-QOS>
            <RELIABILITY>BEST_EFFORT</RELIABILITY>
            <DURABILITY>VOLATILE</DURABILITY>
            <HISTORY>KEEP_LAST</HISTORY>
            <HISTORY-DEPTH>1</HISTORY-DEPTH>
            <LIVELINESS>AUTOMATIC</LIVELINESS>
          </DDS-QOS>
        </DDS-QOS-PROFILE>
        <DDS-TOPIC-CONFIG>
          <SHORT-NAME>CameraObjectDetection</SHORT-NAME>
          <DATA-TYPE>ObjectDetectionData</DATA-TYPE>
          <DESC>Object detection results from camera</DESC>
          <DDS-QOS>
            <RELIABILITY>RELIABLE</RELIABILITY>
            <DURABILITY>VOLATILE</DURABILITY>
            <HISTORY>KEEP_LAST</HISTORY>
            <HISTORY-DEPTH>1</HISTORY-DEPTH>
            <DEADLINE>
              <SEC>0</SEC>
              <NANOSEC>33000000</NANOSEC>
            </DEADLINE>
            <LIVELINESS>AUTOMATIC</LIVELINESS>
          </DDS-QOS>
        </DDS-TOPIC-CONFIG>
        <DDS-TOPIC-CONFIG>
          <SHORT-NAME>CameraImage</SHORT-NAME>
          <DATA-TYPE>ImageData</DATA-TYPE>
          <DESC>Raw camera image data</DESC>
          <DDS-QOS>
            <RELIABILITY>RELIABLE</RELIABILITY>
            <DURABILITY>VOLATILE</DURABILITY>
            <HISTORY>KEEP_LAST</HISTORY>
            <HISTORY-DEPTH>1</HISTORY-DEPTH>
            <LIVELINESS>AUTOMATIC</LIVELINESS>
          </DDS-QOS>
        </DDS-TOPIC-CONFIG>
        <DDS-TOPIC-CONFIG>
          <SHORT-NAME>RadarData</SHORT-NAME>
          <DATA-TYPE>RadarPointCloud</DATA-TYPE>
          <DESC>Radar point cloud data</DESC>
          <DDS-QOS>
            <RELIABILITY>RELIABLE</RELIABILITY>
            <DURABILITY>VOLATILE</DURABILITY>
            <HISTORY>KEEP_LAST</HISTORY>
            <HISTORY-DEPTH>1</HISTORY-DEPTH>
            <LIVELINESS>AUTOMATIC</LIVELINESS>
          </DDS-QOS>
        </DDS-TOPIC-CONFIG>
        <DDS-TOPIC-CONFIG>
          <SHORT-NAME>FusedObjects</SHORT-NAME>
          <DATA-TYPE>ObjectList</DATA-TYPE>
          <DESC>Fused object list from sensor fusion</DESC>
          <DDS-QOS>
            <RELIABILITY>RELIABLE</RELIABILITY>
            <DURABILITY>VOLATILE</DURABILITY>
            <HISTORY>KEEP_LAST</HISTORY>
            <HISTORY-DEPTH>1</HISTORY-DEPTH>
            <LIVELINESS>AUTOMATIC</LIVELINESS>
          </DDS-QOS>
        </DDS-TOPIC-CONFIG>
        <DDS-TRANSPORT-CONFIG>
          <SHORT-NAME>TransportConfig</SHORT-NAME>
          <KIND>UDP</KIND>
          <INTERFACE>eth0</INTERFACE>
          <MULTICAST-ADDRESS>239.255.0.1</MULTICAST-ADDRESS>
          <PORT-BASE>7400</PORT-BASE>
        </DDS-TRANSPORT-CONFIG>
        <DDS-TSN-CONFIG>
          <SHORT-NAME>TSNConfig</SHORT-NAME>
          <ENABLED>true</ENABLED>
          <TSN-STREAM>
            <SHORT-NAME>CameraStream</SHORT-NAME>
            <PRIORITY>7</PRIORITY>
            <BANDWIDTH>10000000</BANDWIDTH>
            <MAX-LATENCY>100000</MAX-LATENCY>
          </TSN-STREAM>
          <TSN-STREAM>
            <SHORT-NAME>ControlStream</SHORT-NAME>
            <PRIORITY>6</PRIORITY>
            <BANDWIDTH>1000000</BANDWIDTH>
            <MAX-LATENCY>50000</MAX-LATENCY>
          </TSN-STREAM>
        </DDS-TSN-CONFIG>
        <DDS-SECURITY-CONFIG>
          <SHORT-NAME>SecurityConfig</SHORT-NAME>
          <ENABLED>false</ENABLED>
        </DDS-SECURITY-CONFIG>
      </ELEMENTS>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>